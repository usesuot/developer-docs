              },
              {
                "group": "Eventos",
                "pages": [
                  "fiscal/mdfe/eventos/cancelamento",
                  "fiscal/mdfe/eventos/encerramento",
                  "fiscal/mdfe/eventos/inclusao-condutor",
                  "fiscal/mdfe/eventos/inclusao-dfe"
