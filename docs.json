              }
            ]
          },
          {
            "group": "Laravel",
            "pages": [
              "fiscal/laravel-bridge",
              "fiscal/laravel-configuracao"
            ]
          },
          {
            "group": "Resultados e erros",
            "pages": [
              "fiscal/resultados",
              "fiscal/rejeicoes",
              "fiscal/retry"
            ]
          }
        ]
      },
      {
        "tab": "Guias & Conceitos",
        "groups": [
          {
            "group": "Guias",
            "pages": [
              "guias/homologacao",
              "guias/producao",
              "guias/ides-ia"
            ]
          },
          {
            "group": "Conceitos",
            "pages": [
