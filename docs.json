  "footer": {
    "socials": {
      "github": "https://github.com/suothub",
      "website": "https://suot.com.br"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "search": {
    "prompt": "Buscar na documentação…"
  },
  "seo": {
    "metatags": {
      "og:locale": "pt_BR"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  }
}
