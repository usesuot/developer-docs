              {
                "group": "Eventos",
                "pages": [
                  "fiscal/cte/eventos/cancelamento",
                  "fiscal/cte/eventos/carta-correcao",
                  "fiscal/cte/eventos/comprovante-entrega",
                  "fiscal/cte/eventos/insucesso-entrega",
                  "fiscal/cte/eventos/prestacao-desacordo"
                ]
              }
            ]
          },
          {
            "group": "CT-e OS",
            "pages": [
              "fiscal/cte-os/index",
              "fiscal/cte-os/emissao",
              "fiscal/cte-os/resultados",
