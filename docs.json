{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SUOT Developers",
  "description": "Documentação técnica da SUOT para SDKs fiscais e Developer Platform. Da ordem ao resultado.",
  "colors": {
    "primary": "#FB0927",
    "light": "#FF2741",
    "dark": "#001145"
  },
  "favicon": "/logo/favicon.png",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "href": "/"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#F5F7FA",
      "dark": "#0c0c0c"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Developer Portal",
        "href": "https://developers.suot.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Começar integração",
      "href": "https://developers.suot.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Início",
        "groups": [
          {
            "group": "Bem-vindo",
            "pages": [
              "index",
              "introducao/ecossistema",
              "introducao/quickstart"
            ]
          },
          {
            "group": "Developer Platform",
            "pages": [
              "platform/organizacoes",
              "platform/licencas",
              "platform/tokens-composer",
              "platform/acesso-packages"
            ]
          }
        ]
      },
      {
        "tab": "Fiscal SDK",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "fiscal/visao-geral",
