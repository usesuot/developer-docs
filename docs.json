              "conceitos/value-objects",
              "conceitos/cqrs",
              "conceitos/licenciamento"
            ]
          },
          {
            "group": "Suporte",
            "pages": [
              "suporte/glossario",
              "suporte/atualizacoes",
              "suporte/contato"
            ]
          }
